{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "S3Access",
            "Effect": "Allow",
            "Action": [
                "s3:*"
            ],
            "Resource": [
                "arn:aws:s3:::${SWRMGR_S3_BUCKET}/${stack}",
                "arn:aws:s3:::${SWRMGR_S3_BUCKET}/${stack}/*"
            ]
        }
    ]
}
