#!/usr/bin/env bash
set -euo pipefail
. "${SWRMGR_ROOT:-/opt/swrmgr}/lib/core.sh"

# ------------------------------------------------------------------------------
# Usage — displayed when the --help flag is provided
# ------------------------------------------------------------------------------
_usage() {
  cat <<EOF
Usage: swrmgr system cleanup [--full]

Run garbage collection on all swarm nodes.

By default runs a light cleanup that is safe while stacks are running:
prunes images, removes dangling volumes, cleans stale network namespaces.

With --full, stops Docker on each node to fix subnet conflicts, vxlan
leaks, and IPAM state corruption. Stacks will go down during this process.

Options:
  --full    Run heavy cleanup (requires Docker restart on each node)

Example:
  swrmgr system cleanup
  swrmgr system cleanup --full
EOF
}

# ------------------------------------------------------------------------------
# Bail out if sourced for --help
# ------------------------------------------------------------------------------
[[ "${1:-}" == "--source-only" ]] && return 0 2>/dev/null || true

mode="light"
[[ "${1:-}" == "--full" ]] && mode="full"

run_hooks "system:cleanup:before"

KEY_FILE="${SWRMGR_SSH_KEY:-/home/ubuntu/.ssh/${NODE_SSH_KEY_NAME}}"
cleanup_script="${SWRMGR_ROOT}/bin/system/_node-cleanup"

# Run on the manager first
echo "Cleaning up $(hostname) (${mode})..."
bash "${cleanup_script}" "${mode}"

# Then SSH to each worker
while read -r node; do
  [[ -z "${node}" ]] && continue
  [[ "${node}" == "$(docker_hostname)" ]] && continue
  echo "Cleaning up ${node} (${mode})..."
  ssh -i "${KEY_FILE}" "ubuntu@${node}" "bash -s ${mode}" < "${cleanup_script}"
done <<< "$(swrmgr system node-list)"

run_hooks "system:cleanup:after"
