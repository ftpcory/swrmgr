#!/usr/bin/env bash
set -euo pipefail

result="$(docker node ls --format '{{.Hostname}} {{.ManagerStatus}}' \
  | grep -v -i 'leader' \
  | awk '{print $1}' \
  | shuf -n1 || true)"

# Fallback to the first node in the swarm
[[ -n "${result}" ]] || result="$(docker node ls --format '{{.Hostname}}' | head -1)"

echo "${result}"
