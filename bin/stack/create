#!/usr/bin/env bash
set -euo pipefail
. "${SWRMGR_ROOT:-/opt/swrmgr}/lib/core.sh"

# ------------------------------------------------------------------------------
# Usage — displayed when the --help flag is provided
# ------------------------------------------------------------------------------
_usage() {
  cat <<EOF
Usage: swrmgr stack create <stack-name> [--template <name>] [customer name]

Full provisioning pipeline for a new stack. Runs init, up, waits for
services to start, fires post-create hooks, and registers DNS records.

Arguments:
  stack-name      Name of the stack to create
  customer name   Optional display name for the customer

Options:
  --template <name>   Use a stack template (defines services, env defaults, IAM)

Example:
  swrmgr stack create acme-corp
  swrmgr stack create mysite.com --template wordpress
  swrmgr stack create acme-corp --template laravel "Acme Corporation"

Available templates:
  swrmgr system template-list
EOF
}

# ------------------------------------------------------------------------------
# Bail out if sourced for --help
# ------------------------------------------------------------------------------
[[ "${1:-}" == "--source-only" ]] && return 0 2>/dev/null || true

stack="$(stack_name "${1}")"
stack_raw="$(stack_id "${1}")"
shift 1

template=""
name=""

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --template) shift; template="${1}" ;;
    *) name="${name:+${name} }${1}" ;;
  esac
  shift
done

name="${name:-${stack}}"

# Validate template if specified
if [[ -n "${template}" ]]; then
  resolve_template "${template}" > /dev/null || exit 1
fi

run_hooks "stack:create:before" "${stack}" "${name}"

swrmgr stack init "${stack_raw}" ${template:+--template "${template}"}
swrmgr stack up "${stack_raw}"

# Wait for services to start
echo "Waiting for stack to start up..."
init="${SECONDS}"
while (( SECONDS - init < ${SWRMGR_CREATE_WAIT:-120} )); do
  sleep 1
done

run_hooks "stack:create:after" "${stack}" "${name}"

# DNS registration
swrmgr aws dns-create "${stack}"
