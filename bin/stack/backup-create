#!/usr/bin/env bash
set -euo pipefail
. "${SWRMGR_ROOT:-/opt/swrmgr}/lib/core.sh"

# ------------------------------------------------------------------------------
# Usage — displayed when the --help flag is provided
# ------------------------------------------------------------------------------
_usage() {
  cat <<EOF
Usage: swrmgr stack backup-create <stack-name> [--cold]

Create an encrypted backup of the stack's database and upload to S3.

By default performs a hot backup using mariadb-backup while the stack
stays running. No downtime required.

With --cold, stops the stack first and copies the raw volume data.
This is the legacy behavior and guarantees a fully quiesced filesystem.

Arguments:
  stack-name    Name of the stack to backup

Options:
  --cold        Stop the stack during backup (legacy mode)

Example:
  swrmgr stack backup-create acme-corp
  swrmgr stack backup-create acme-corp --cold
EOF
}

# ------------------------------------------------------------------------------
# Bail out if sourced for --help
# ------------------------------------------------------------------------------
[[ "${1:-}" == "--source-only" ]] && return 0 2>/dev/null || true

stack="$(stack_name "${1}")"
mode="hot"
[[ "${2:-}" == "--cold" ]] && mode="cold"

folder="$(stack_path "${stack}")"
cd "${folder}" || exit 1

pass="$(swrmgr stack env-get "${stack}" mariadb_root_password)"
node="$(swrmgr stack env-get "${stack}" database_node)"
domain="$(stack_domain "${stack}")"
host="$(hostname)"
timestamp="$(date +%s)"
bucket="${SWRMGR_S3_BUCKET:?SWRMGR_S3_BUCKET is not set}"
file="${stack}_dbdata"

[[ -n "${node}" ]] || exit 1
[[ -n "${pass}" ]] || exit 1

run_hooks "stack:backup:before" "${stack}"

KEY_FILE="${SWRMGR_SSH_KEY:-/home/ubuntu/.ssh/${NODE_SSH_KEY_NAME}}"

if [[ "${mode}" == "hot" ]]; then
  # -------------------------------------------------------------------------
  # Hot backup — mariadb-backup streamed from the running container
  # -------------------------------------------------------------------------
  container="$(swrmgr stack _container "${stack}" "db")"
  [[ -n "${container}" ]] || { echo "Could not find db container for ${stack}" >&2; exit 1; }

  echo "Hot backup: ${stack} on ${node}..."

  # Run mariadb-backup inside the container and stream the tar to the manager
  ssh -i "${KEY_FILE}" "${node}" \
    "docker exec ${container} mariadb-backup \
      --backup \
      --stream=xbstream \
      --user=root \
      --password='${pass}' \
      --target-dir=/tmp/backup" \
    | openssl enc -aes-256-cbc -salt -pbkdf2 -pass pass:"${pass}" \
      -out "${file}.xbstream.enc"

else
  # -------------------------------------------------------------------------
  # Cold backup — stop stack, copy volume, restart
  # -------------------------------------------------------------------------
  echo "Cold backup: ${stack} on ${node}..."
  echo "${node}"
  mkdir -p "${file}"

  swrmgr stack down "${stack}"
  sleep 10

  ssh -n -i "${KEY_FILE}" "${node}" \
    sudo tar czf - -C "/var/lib/docker/volumes/${file}" . \
    | tar xzf - -C "${file}"

  tar -czf - -C "${file}" . \
    | openssl enc -aes-256-cbc -salt -pbkdf2 -pass pass:"${pass}" \
      -out "${file}.tar.gz.enc"

  swrmgr stack up "${stack}"
  rm -rf "${file}"
fi

# Upload to S3
enc_file="$(ls ${file}.* 2>/dev/null | head -1)"
[[ -f "${enc_file}" ]] || { echo "No backup file found" >&2; exit 1; }

aws s3api put-object \
  --bucket "${bucket}" \
  --key "${stack}/backups/${timestamp}-$(basename "${enc_file}")" \
  --body "${enc_file}" \
  --tagging "stack=${stack}&domain=${domain}&host=${host}&mode=${mode}"

if [[ $? -ne 0 ]]; then
  rm -f "${enc_file}" 2>/dev/null
  echo "Failed to upload backup to S3" >&2
  exit 2
fi

rm -f "${enc_file}" 2>/dev/null

run_hooks "stack:backup:after" "${stack}"
