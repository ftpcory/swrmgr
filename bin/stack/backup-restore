#!/usr/bin/env bash
set -euo pipefail
. "${SWRMGR_ROOT:-/opt/swrmgr}/lib/core.sh"

# ------------------------------------------------------------------------------
# Usage — displayed when the --help flag is provided
# ------------------------------------------------------------------------------
_usage() {
  cat <<EOF
Usage: swrmgr stack backup-restore <stack-name> [--cold] [--node <node>] [--hold]

Restore a backup to the stack's database node.

By default performs a hot restore: stops only the db service, runs
mariadb-backup --prepare and --copy-back, then restarts the service.
The rest of the stack stays up.

With --cold, restores from a raw volume tarball using the legacy
method (rsync --delete). Requires the full stack to be down.

Arguments:
  stack-name    Name of the stack to restore

Options:
  --cold        Restore from a cold (volume tar) backup
  --node <n>    Target node (defaults to stack's DATABASE_NODE)
  --hold        Keep the db service (or stack in cold mode) down after restore

Example:
  swrmgr stack backup-restore acme-corp
  swrmgr stack backup-restore acme-corp --cold --node worker-03 --hold
EOF
}

# ------------------------------------------------------------------------------
# Bail out if sourced for --help
# ------------------------------------------------------------------------------
[[ "${1:-}" == "--source-only" ]] && return 0 2>/dev/null || true

stack="$(stack_name "${1}")"
shift

mode="hot"
node=""
hold=""

while [[ $# -gt 0 ]]; do
  case "${1}" in
    --cold) mode="cold" ;;
    --node) shift; node="${1}" ;;
    --hold) hold="true" ;;
    *) ;;
  esac
  shift
done

folder="$(stack_path "${stack}")"
cd "${folder}" || exit 1

[[ -z "${node}" ]] && node="$(swrmgr stack env-get "${stack}" database_node)"
pass="$(swrmgr stack env-get "${stack}" mariadb_root_password)"

[[ -n "${node}" ]] || { echo "Could not determine database node" >&2; exit 1; }
[[ -n "${pass}" ]] || { echo "Could not determine database password" >&2; exit 1; }

KEY_FILE="${SWRMGR_SSH_KEY:-/home/ubuntu/.ssh/${NODE_SSH_KEY_NAME}}"

run_hooks "stack:restore:before" "${stack}"

if [[ "${mode}" == "hot" ]]; then
  # -------------------------------------------------------------------------
  # Hot restore — from mariadb-backup xbstream
  # -------------------------------------------------------------------------
  enc_file="$(ls -t ${stack}_dbdata.xbstream.enc 2>/dev/null | head -1)"
  [[ -f "${enc_file}" ]] || { echo "No xbstream backup found in ${folder}" >&2; exit 1; }

  container="$(swrmgr stack _container "${stack}" "db")"
  [[ -n "${container}" ]] || { echo "Could not find db container for ${stack}" >&2; exit 1; }

  echo "Hot restore: ${stack} on ${node}..."

  # Scale db to 0 — stops only the database, rest of the stack stays up
  docker service scale "${stack}_db=0" --detach=false

  # Decrypt and stream to a staging directory on the node
  echo "Staging backup on ${node}..."
  openssl enc -d -aes-256-cbc -pbkdf2 -pass pass:"${pass}" -in "${enc_file}" \
    | ssh -i "${KEY_FILE}" "${node}" \
      "sudo mkdir -p /tmp/${stack}_restore && cd /tmp/${stack}_restore && mbstream -x"

  # Prepare the backup (apply redo log)
  echo "Preparing backup..."
  ssh -i "${KEY_FILE}" "${node}" \
    "sudo mariadb-backup --prepare --target-dir=/tmp/${stack}_restore"

  # Clear the existing data directory and copy back
  echo "Restoring data..."
  ssh -i "${KEY_FILE}" "${node}" \
    "sudo rm -rf /var/lib/docker/volumes/${stack}_dbdata/_data/*"

  ssh -i "${KEY_FILE}" "${node}" \
    "sudo mariadb-backup --copy-back --target-dir=/tmp/${stack}_restore \
      --datadir=/var/lib/docker/volumes/${stack}_dbdata/_data"

  # Fix permissions
  ssh -i "${KEY_FILE}" "${node}" \
    "sudo chown -R lxd:docker /var/lib/docker/volumes/${stack}_dbdata/_data/"

  # Cleanup staging
  ssh -i "${KEY_FILE}" "${node}" \
    "sudo rm -rf /tmp/${stack}_restore"

  # Bring the db back up
  if [[ -z "${hold}" ]]; then
    docker service scale "${stack}_db=1" --detach=false
  else
    echo "Database left scaled to 0. Run: docker service scale ${stack}_db=1"
  fi

else
  # -------------------------------------------------------------------------
  # Cold restore — from raw volume tarball
  # -------------------------------------------------------------------------
  [[ -d _data ]] || { echo "No _data directory found in ${folder}" >&2; exit 1; }

  echo "Cold restore: ${stack} on ${node}..."

  swrmgr stack down "${stack}"

  rsync -ra --delete --quiet --mkpath _data "${node}:/home/ubuntu/${stack}_dbdata"
  ssh -n -i "${KEY_FILE}" "${node}" \
    "sudo rsync -ra --delete --quiet --mkpath /home/ubuntu/${stack}_dbdata /var/lib/docker/volumes/"
  ssh -n -i "${KEY_FILE}" "${node}" \
    "sudo rm -rf /home/ubuntu/${stack}_dbdata"

  # Fix permissions
  ssh -n -i "${KEY_FILE}" "${node}" \
    "sudo chown -R root:root /var/lib/docker/volumes/${stack}_dbdata"
  ssh -n -i "${KEY_FILE}" "${node}" \
    "sudo chown -R lxd:docker /var/lib/docker/volumes/${stack}_dbdata/_data/"

  if [[ -z "${hold}" ]]; then
    swrmgr stack up "${stack}"
  else
    echo "Stack left down. Run: swrmgr stack up ${stack}"
  fi
fi

run_hooks "stack:restore:after" "${stack}"
